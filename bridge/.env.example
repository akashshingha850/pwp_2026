# MQTT broker (same EMQX Cloud instance the Pi uses)
MQTT_BROKER=q1fd1412.ala.eu-central-1.emqxsl.com
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=1

# Topics (defaults match auxiliary/motion/motion.py and config/config_sub.py)
MOTION_TOPIC=pwp/motion
CONFIG_TOPIC=pwp/config

# Django REST API
API_BASE=http://127.0.0.1:8000
API_TOKEN=4ffd30385e756f5b08989a324342d562202e75cd

# MAC → Camera UUID mapping (comma-separated mac=uuid pairs)
# Get the UUID from /api/cameras/ after creating the camera in the UI/API.
CAMERA_MAP=aa:bb:cc:dd:ee:ff=00000000-0000-0000-0000-000000000000

# Bridge file server (serves captured JPEGs so API filepath URLs resolve)
BRIDGE_HTTP_HOST=0.0.0.0
BRIDGE_HTTP_PORT=9000
BRIDGE_PUBLIC_URL=http://127.0.0.1:9000
CAPTURES_DIR=./captures

# How often to poll /api/cameras/ for config-push diffs
POLL_INTERVAL=10

# Defaults for MotionEvent records (Pi doesn't send these today)
DEFAULT_MOTION_DURATION=0.0
DEFAULT_MOTION_THRESHOLD=0.05
